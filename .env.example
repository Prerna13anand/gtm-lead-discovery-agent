# Azure OpenAI (configuration/init only in Phase 1 — no prompts or scoring yet)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Apollo (Stage 6, lead discovery — spec §9). Implemented in Phase 3; unset
# here means live verification against the real Apollo API was not possible
# in this environment (see project report).
APOLLO_API_KEY=

# People Data Labs (Stage 8, enrichment — spec §11). Implemented in Phase 3;
# unset here for the same reason as Apollo above.
PDL_API_KEY=

# Tavily (Stage 1 source-resolution fallback, and Stage 9 company context —
# spec §12). Implemented; unset here for the same reason as Apollo above.
TAVILY_API_KEY=

# Database
DATABASE_URL=

# Fetch layer
HTTP_USER_AGENT=GTM-Lead-Discovery-Agent/0.1 (+mailto:reubenjacob@syphonlabs.com)
HTTP_TIMEOUT_SECONDS=15

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# scrape_run ledger (spec §15.1) — local JSONL file until a real database exists
SCRAPE_RUN_LEDGER_PATH=.data/scrape_runs.jsonl
RAW_PAYLOAD_ARCHIVE_DIR=.data/raw_payloads

# Part II stores (spec §15.2) — same local-JSONL pattern
LEAD_STORE_PATH=.data/leads.jsonl
LEAD_DISCOVERY_RUN_PATH=.data/lead_discovery_runs.jsonl
LEAD_JOB_MATCH_PATH=.data/lead_job_matches.jsonl
UNMATCHED_JOB_PATH=.data/unmatched_jobs.jsonl
COMPANY_CONTEXT_PATH=.data/company_contexts.jsonl
LEAD_FEEDBACK_PATH=.data/lead_feedback.jsonl

# Credit budget ceilings (spec §18.3) — per-sweep; conservative defaults, not
# a production allowance (open question §23.14 has no real figure yet)
APOLLO_CREDIT_CEILING=500
PDL_CREDIT_CEILING=500
TAVILY_CALL_CEILING=500

# Part III stores (spec §15.2, §14) — same local-JSONL pattern
SCORED_LEAD_PATH=.data/scored_leads.jsonl
PUBLICATION_EVENT_PATH=.data/publication_events.jsonl
GTM_LEAD_TABLE_PATH=.data/gtm_leads.jsonl
GTM_LEAD_CSV_PATH=.data/gtm_leads.csv

# Compliance (spec §21.6, Phase 5)
COMPANY_DENYLIST_PATH=.data/company_denylist.jsonl
PERSON_SUPPRESSION_PATH=.data/person_suppression.jsonl
